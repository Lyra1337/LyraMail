@page "/inbox"

<TitleControl Title="Mailbox" />

<div class="row no-gutters mt-3 mailbox-container">
    <div class="col-sm-6 col-md-5 col-lg-4 mail-list-column @(this.CurrentMail != null ? "d-none d-sm-block" : "")">
        <RadzenDataList @ref="dataList"
                        AllowPaging="true"
                        Data="@pagedMails"
                        Count="@totalCount"
                        PageSize="@pageSize"
                        LoadData="@LoadData"
                        TItem="MailPreviewDto"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        ShowPagingSummary="true"
                        PagingSummaryFormat="@("Showing page {0} of {1} (total {2} records)")">
            <Template Context="mail">
                <a href="javascript:void(0)"
                    @onclick="async () => await this.ShowMail(mail)"
                    class="list-group-item list-group-item-action flex-column align-items-start @(this.CurrentMail?.Id == mail.Id ? "active" : "")">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1 text-break">
                            @mail.FromAddress
                        </h5>
                        <small>@mail.ReceivedDate.ToLocalTime().ToShortTimeString()</small>
                    </div>
                    <strong class="text-break">
                        @if (mail.IsRead == true)
                        {
                            <i class="far fa-envelope-open me-2"></i>
                        }
                        else
                        {
                            <i class="fas fa-envelope me-2"></i>
                        }

                        @this.Truncate(mail.Subject, 50)
                    </strong>
                    <p class="my-1 text-break">
                        @mail.PreviewText
                    </p>
                </a>
            </Template>
        </RadzenDataList>
    </div>
    <div class="col-sm-6 col-md-7 col-lg-8 mail-content-column @(this.CurrentMail == null ? "d-none d-sm-block" : "")">
        @if (this.CurrentMail != null)
        {
            <Card Class="mail-detail-card h-100">
                <Title>
                    <button class="btn btn-secondary d-inline-block d-sm-none me-2" @onclick="this.CloseMail">
                        <i class="fas fa-arrow-left"></i>
                    </button>

                    <strong class="text-break pt-1">
                        @this.CurrentMail.Subject
                    </strong>

                    <button class="btn btn-sm btn-danger float-end" @onclick="this.DeleteCurrentMail">
                        <i class="fas fa-trash"></i>
                    </button>
                </Title>
                <Body>
                    @if (String.IsNullOrWhiteSpace(this.CurrentMail.BodyHtml) == false)
                    {
                        <iframe src="@this.WebServerConfiguration.MailContentBaseUrl/Api/HtmlContent/@(Uri.EscapeDataString(this.UserState.CurrentMailbox))/@(this.CurrentMail.Secret)?privateKey=@Uri.EscapeDataString(this.UserState.Secret.Value.PrivateKey)"
                                class="mail-iframe h-100"
                                sandbox="allow-popups"></iframe>
                    }
                    else
                    {
                        <pre class="mail-text-preview text-break">@this.CurrentMail.BodyText</pre>
                    }
                </Body>
            </Card>
        }
    </div>
</div>